# =============================================================================
# .gitignore pour projet .NET 9 / Clean Architecture
# =============================================================================

# ── Build & Artifacts ─────────────────────────────────────────────────────────
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
artifacts/
out/
publish/

# ── .NET specifique ───────────────────────────────────────────────────────────
project.lock.json
project.fragment.lock.json
*.user
*.suo
.vs/
*.rsuser
.localhistory/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
!**/packages/build/

# ── ASP.NET Core ─────────────────────────────────────────────────────────────
# Secrets locaux (jamais commiter ces fichiers !)
**/appsettings.Development.json
**/appsettings.Local.json
**/appsettings.Production.json
**/secrets.json
**/*.pfx
**/*.p12

# ── Entity Framework Core ─────────────────────────────────────────────────────
# Ne pas ignorer les Migrations (elles sont versionnees)
# Ignorer les fichiers generes par le scaffold EF
ScaffoldingReadMe.txt

# ── Tests ─────────────────────────────────────────────────────────────────────
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml
coverage/
*.coverage
*.coveragexml
*.trx
lcov.info
CoverageReport/

# ── Editeurs & IDEs ───────────────────────────────────────────────────────────
# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains Rider / ReSharper
.idea/
*.sln.iml
_ReSharper*/
*.DotSettings.user
*.dotCover

# Visual Studio
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.vc.vc.opendb
*.psess
*.vsp
*.vspx
*.sap

# ── OS ────────────────────────────────────────────────────────────────────────
